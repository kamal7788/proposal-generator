generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String
  image         String?
  role          String    @default("admin")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  proposals     Proposal[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Proposal {
  id                    String    @id @default(cuid())
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName          String
  contactName           String?
  contactEmail          String?
  contactPhone          String?
  address               String?
  websiteUrl            String?
  googleMapsLink        String?
  googleBusinessProfile String?
  industry              String?
  serviceArea           String?
  brandNotes            String?   @db.Text
  discoveryNotes        String?   @db.Text
  painPoints            String?   @db.Text
  goals                 String?   @db.Text
  currentLeadVolume     String?
  currentMonthlyTraffic String?
  approximateRevenue    String?
  existingCrm           String?
  competitors           String?   @db.Text
  logoUrl               String?
  currency              String    @default("USD")
  websiteSpeedScore     Int?
  lighthousePerformance Int?
  lighthouseAccessibility Int?
  lighthouseSeo         Int?
  lighthouseBestPractices Int?
  googleProfileScore    Int?
  localSeoScore         Int?
  status                String    @default("draft")
  shareSlug             String    @unique
  passwordHash          String?
  generatedContent      Json?
  sectionsOrder         Json?
  deletionRequested     Boolean   @default(false)
  deletionReason        String?   @db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  services              ProposalService[]
  sections              ProposalSection[]
  auditItems            AuditItem[]
  assumptions           Assumption[]
  assets                UploadedAsset[]

  @@map("proposals")
}

model Service {
  id               String            @id @default(cuid())
  name             String
  shortDescription String?
  description      String?           @db.Text
  outcomes         String?           @db.Text
  deliverables     String?           @db.Text
  useCases         String?           @db.Text
  pricingNotes     String?           @db.Text
  proofPoints      String?           @db.Text
  timeline         String?
  addOns           String?           @db.Text
  pricingPackages  Json?
  isActive         Boolean           @default(true)
  sortOrder        Int               @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  proposals        ProposalService[]
  caseStudies      CaseStudy[]

  @@map("services")
}

model ProposalService {
  id            String   @id @default(cuid())
  proposalId    String
  serviceId     String
  proposal      Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  service       Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  packageName   String?
  packagePrice  Float?
  customPrice   Float?
  notes         String?  @db.Text

  @@unique([proposalId, serviceId])
  @@map("proposal_services")
}

model ReusableSection {
  id        String            @id @default(cuid())
  title     String
  content   String            @db.Text
  category  String?
  sortOrder Int               @default(0)
  isDefault Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  sections  ProposalSection[]

  @@map("reusable_sections")
}

model ProposalSection {
  id                String           @id @default(cuid())
  proposalId        String
  reusableSectionId String?
  title             String
  content           String           @db.Text
  sortOrder         Int              @default(0)
  isVisible         Boolean          @default(true)
  isOverridden      Boolean          @default(false)
  type              String           @default("reusable")
  proposal          Proposal         @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  reusableSection   ReusableSection? @relation(fields: [reusableSectionId], references: [id], onDelete: SetNull)

  @@map("proposal_sections")
}

model CaseStudy {
  id        String    @id @default(cuid())
  title     String
  summary   String?   @db.Text
  metrics   Json?
  imageUrl  String?
  content   String?   @db.Text
  serviceId String?
  service   Service?  @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("case_studies")
}

model Testimonial {
  id         String   @id @default(cuid())
  quote      String   @db.Text
  authorName String
  authorRole String?
  company    String?
  createdAt  DateTime @default(now())

  @@map("testimonials")
}

model AuditItem {
  id               String   @id @default(cuid())
  proposalId       String
  category         String
  title            String
  screenshotUrl    String?
  currentIssue     String?  @db.Text
  whyItMatters     String?  @db.Text
  keyTakeaway      String?  @db.Text
  recommendations  String?  @db.Text
  mappedServiceIds Json?
  revenueImpact    String?
  priority         String   @default("medium")
  sortOrder        Int      @default(0)
  proposal         Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("audit_items")
}

model Assumption {
  id            String   @id @default(cuid())
  proposalId    String
  type          String
  label         String
  lowValue      Float
  expectedValue Float
  highValue     Float
  unit          String   @default("percent")
  proposal      Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("assumptions")
}

model UploadedAsset {
  id           String   @id @default(cuid())
  proposalId   String
  filename     String
  originalName String
  mimeType     String
  size         Int
  path         String
  proposal     Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@map("uploaded_assets")
}
